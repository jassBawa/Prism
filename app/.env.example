# All values are OPTIONAL — app/lib/constants.ts ships with these live-devnet
# defaults baked in, so `pnpm dev` works with no env at all. Copy to .env.local
# only to override (e.g. a faster RPC, your own seed, or a local validator).

# A devnet RPC. Public one below is rate-limited; a free Helius devnet key is smoother.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# The deployed program id.
NEXT_PUBLIC_PROGRAM_ID=8TrJeQaHV4yXgPkNeZXR1pdWbEMXvnpLMYZpk1qX3jbe

# Test-mint addresses per asset (only needed for the create-basket form).
NEXT_PUBLIC_MINTS={"sol":"BPgaZJyFNVpcYcKQLiUL5u28rFhFKidKU1h3MhNkfKWE","jup":"2uBkvi6E332exDsk8mw3ToDbjEsepuEmnCJeS4HGmTP4","bonk":"6BVicGVPCN6F6a8buVqH9b3TxpsNVqjEhz4BzEBmHCm5","usdc":"DhuAw2uxXP5r9ufdsPs25Kk98ippMSss2brrxzBsQy5E"}

# Ops faucet URL (empty = hide the in-app "Get test funds" button; fund via `pnpm fund <wallet>` instead).
NEXT_PUBLIC_FAUCET_URL=
